<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BDR Scorecard · Enable</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
:root {
  /* Enable Primary Palette */
  --core-green:#00684A;
  --mid-green:#00A74C;
  --lumi-green:#00F752;
  --mid-teal:#15BB7F;
  --impact-blue:#00B8D7;
  --slate-800:#1F2A30;
  --white:#FFFFFF;

  /* Enable Neutral Palette */
  --slate-50:#F8FAFB;
  --slate-100:#F1F4F6;
  --slate-200:#E4E9EC;
  --slate-300:#CED7DC;
  --slate-400:#95A5AC;
  --slate-500:#64757E;
  --slate-600:#475761;
  --slate-700:#364349;
  --slate-900:#0C1318;

  /* Enable Secondary Palette */
  --amber:#FFB84D;
  --coral:#FF6B6B;
  --violet:#8B5CF6;
  --sapphire:#2563EB;
  --magenta:#FF3E9D;

  /* UI Mappings (light theme, Enable brand) */
  --bg: var(--slate-50);
  --bg2: var(--white);
  --bg3: var(--slate-100);
  --bg4: var(--slate-200);
  --border: var(--slate-200);
  --border2: var(--slate-300);
  --text: var(--slate-800);
  --text2: var(--slate-600);
  --text3: var(--slate-400);

  /* Accent = Mid Green (brand primary) */
  --accent: var(--mid-green);
  --accent2: var(--core-green);
  --accent-dim: rgba(0,167,76,0.08);
  --accent-border: rgba(0,167,76,0.25);

  --blue: var(--impact-blue);
  --blue-dim: rgba(0,184,215,0.1);
  --amber-dim: rgba(255,184,77,0.12);
  --red: var(--coral);
  --red-dim: rgba(255,107,107,0.1);
  --purple: var(--violet);
  --teal: var(--mid-teal);

  --radius: 6px;
  --radius-lg: 10px;
  --radius-xl: 14px;
  --shadow-sm: 0 1px 3px rgba(31,42,48,0.06), 0 1px 2px rgba(31,42,48,0.04);
  --shadow: 0 4px 12px rgba(31,42,48,0.08), 0 1px 3px rgba(31,42,48,0.04);
  --shadow-lg: 0 8px 24px rgba(31,42,48,0.1), 0 2px 6px rgba(31,42,48,0.06);
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:'Plus Jakarta Sans',Arial,sans-serif;font-size:14px}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:var(--slate-100)}
::-webkit-scrollbar-thumb{background:var(--slate-300);border-radius:2px}

.app{display:flex;height:100vh;overflow:hidden}

/* ── SIDEBAR ── */
.sidebar{
  width:220px;flex-shrink:0;
  background:var(--slate-800);
  display:flex;flex-direction:column;
  position:relative;overflow:hidden;
}
/* Subtle three-tiered flow decoration in sidebar */
.sidebar::before{
  content:'';position:absolute;bottom:60px;left:-10px;right:-10px;height:80px;
  background: repeating-linear-gradient(
    to bottom,
    transparent 0, transparent 6px,
    rgba(0,247,82,0.06) 6px, rgba(0,247,82,0.06) 10px,
    transparent 10px, transparent 14px,
    rgba(0,247,82,0.04) 14px, rgba(0,247,82,0.04) 18px,
    transparent 18px, transparent 22px,
    rgba(0,247,82,0.03) 22px, rgba(0,247,82,0.03) 26px
  );
  pointer-events:none;
}
.sidebar-logo{
  padding:24px 20px 20px;
  border-bottom:1px solid rgba(255,255,255,0.07);
  display:flex;align-items:center;gap:10px;
}
.logo-icon{
  width:32px;height:32px;border-radius:7px;
  background:linear-gradient(135deg, var(--mid-green), var(--lumi-green));
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:3px;
  flex-shrink:0;padding:7px 6px;
}
.logo-bar{height:3px;border-radius:2px;background:var(--slate-800)}
.logo-bar:nth-child(1){width:100%}
.logo-bar:nth-child(2){width:65%;align-self:flex-start}
.logo-bar:nth-child(3){width:80%}
.logo-text{display:flex;flex-direction:column}
.logo-wordmark{font-size:15px;font-weight:800;color:#fff;line-height:1;letter-spacing:-0.02em}
.logo-sub{font-size:10px;color:rgba(255,255,255,0.4);font-weight:500;margin-top:2px;letter-spacing:0.04em;text-transform:uppercase}
.sidebar-nav{flex:1;padding:12px 0;overflow-y:auto}
.nav-section{
  padding:4px 16px;
  font-size:9px;font-weight:700;color:rgba(255,255,255,0.25);
  letter-spacing:.12em;text-transform:uppercase;margin-top:12px;margin-bottom:4px;
}
.nav-item{
  display:flex;align-items:center;gap:10px;
  padding:9px 16px;cursor:pointer;
  color:rgba(255,255,255,0.5);
  transition:all .15s;border-radius:0;
  font-size:13px;font-weight:600;
  margin:1px 8px;border-radius:var(--radius);
  position:relative;
}
.nav-item svg{width:16px;height:16px;flex-shrink:0}
.nav-item:hover{color:rgba(255,255,255,0.85);background:rgba(255,255,255,0.07)}
.nav-item.active{
  color:#fff;
  background:linear-gradient(135deg,rgba(0,167,76,0.3),rgba(21,187,127,0.2));
  border:1px solid rgba(0,247,82,0.2);
}
.nav-item.active::before{
  content:'';position:absolute;left:0;top:50%;transform:translateY(-50%);
  width:3px;height:16px;border-radius:2px;
  background:linear-gradient(to bottom, var(--lumi-green), var(--mid-teal));
}

/* ── MAIN ── */
.main{flex:1;overflow-y:auto;display:flex;flex-direction:column;min-width:0;background:var(--slate-50)}
.topbar{
  padding:18px 32px;
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;flex-shrink:0;
  background:var(--white);
  box-shadow:var(--shadow-sm);
}
.topbar h2{font-size:19px;font-weight:800;color:var(--slate-800);letter-spacing:-0.02em}
.topbar .sub{font-size:11px;color:var(--text3);margin-top:2px;font-weight:500}
.content{padding:24px 32px;flex:1}
.page{display:none}.page.active{display:block}

/* ── METRIC CARDS ── */
.metrics-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:22px}
.metric-card{
  background:var(--white);border:1px solid var(--border);
  border-radius:var(--radius-lg);padding:16px 18px;
  box-shadow:var(--shadow-sm);
  position:relative;overflow:hidden;
}
.metric-card::after{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg, var(--mid-green), var(--mid-teal));
  opacity:0;transition:opacity .2s;
}
.metric-card:hover::after{opacity:1}
.metric-card .label{
  font-size:10px;font-weight:700;color:var(--text3);
  text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px;
}
.metric-card .value{font-size:26px;font-weight:800;line-height:1;color:var(--slate-800);letter-spacing:-0.02em}
.metric-card .change{font-size:11px;margin-top:6px;color:var(--text3);font-weight:500}

/* ── CARDS ── */
.card{
  background:var(--white);border:1px solid var(--border);
  border-radius:var(--radius-lg);padding:20px 22px;margin-bottom:16px;
  box-shadow:var(--shadow-sm);
}
.card-title{
  font-size:11px;font-weight:700;color:var(--slate-700);margin-bottom:14px;
  display:flex;align-items:center;gap:8px;
  text-transform:uppercase;letter-spacing:.07em;
}
.card-title .dot{width:5px;height:5px;border-radius:50%;flex-shrink:0}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:16px}

/* ── SKILL CATEGORIES ── */
.skill-cat{
  background:var(--white);border:1px solid var(--border);
  border-radius:var(--radius-lg);padding:14px 16px;margin-bottom:12px;
  box-shadow:var(--shadow-sm);
  transition:border-color .15s;
}
.skill-cat:hover{border-color:var(--slate-300)}
.skill-cat-header{display:flex;align-items:center;gap:8px;margin-bottom:10px;padding-bottom:9px;border-bottom:1px solid var(--border)}
.cat-icon{
  width:26px;height:26px;border-radius:var(--radius);
  display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;
}
.cat-label{font-size:12px;font-weight:700;flex:1;color:var(--slate-700)}
.cat-avg-badge{
  font-size:11px;font-weight:700;color:var(--slate-600);
  background:var(--slate-100);padding:2px 8px;border-radius:4px;
  border:1px solid var(--border);
}
.star-row{display:flex;align-items:center;margin-bottom:8px}
.star-row:last-child{margin-bottom:0}
.star-name{font-size:12px;color:var(--text2);flex:1;padding-right:10px;line-height:1.35;font-weight:500}
.stars{display:flex;gap:3px;flex-shrink:0}
.star{width:19px;height:19px;cursor:pointer;transition:transform .1s;flex-shrink:0}
.star:hover{transform:scale(1.2)}
.star svg{width:19px;height:19px;display:block}
.star-num{font-size:10px;font-weight:700;color:var(--text3);width:14px;text-align:right;flex-shrink:0;margin-left:4px}

/* ── FORMS ── */
.fgroup{display:flex;flex-direction:column;gap:5px;margin-bottom:13px}
.fgroup label{font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.08em}
input,select{
  background:var(--slate-50);border:1px solid var(--border2);
  border-radius:var(--radius);padding:9px 12px;
  color:var(--text);font-family:'Plus Jakarta Sans',Arial,sans-serif;
  font-size:13px;font-weight:500;width:100%;outline:none;transition:border .15s, box-shadow .15s;
}
input:focus,select:focus{
  border-color:var(--mid-green);
  box-shadow:0 0 0 3px rgba(0,167,76,0.12);
  background:var(--white);
}
select option{background:var(--white)}
input[type=month]{color-scheme:light}
input[type=number]::-webkit-inner-spin-button{opacity:0.5}

/* ── BUTTONS ── */
.btn{
  padding:9px 18px;border-radius:var(--radius);
  font-family:'Plus Jakarta Sans',Arial,sans-serif;
  font-size:13px;font-weight:700;cursor:pointer;
  transition:all .15s;border:1px solid transparent;letter-spacing:0.01em;
}
.btn-primary{
  background:linear-gradient(135deg, var(--mid-green), var(--core-green));
  color:#fff;border-color:var(--core-green);
  box-shadow:0 2px 8px rgba(0,167,76,0.3);
}
.btn-primary:hover{
  background:linear-gradient(135deg, var(--lumi-green), var(--mid-green));
  color:var(--slate-800);box-shadow:0 4px 12px rgba(0,167,76,0.4);
  transform:translateY(-1px);
}
.btn-ghost{
  background:transparent;color:var(--text2);
  border-color:var(--border2);
}
.btn-ghost:hover{background:var(--slate-100);color:var(--slate-700)}
.btn-danger{background:transparent;color:var(--coral);border-color:rgba(255,107,107,0.3)}
.btn-danger:hover{background:var(--red-dim)}
.btn-sm{padding:5px 11px;font-size:11px}
.btns{display:flex;gap:10px;flex-wrap:wrap;align-items:center}

/* ── COMPOSITE BOX ── */
.comp-box{
  background:linear-gradient(135deg, var(--slate-800) 0%, var(--slate-700) 100%);
  border:1px solid var(--slate-700);border-radius:var(--radius-lg);
  padding:18px 20px;display:flex;justify-content:space-between;align-items:center;
  margin:14px 0;box-shadow:var(--shadow);position:relative;overflow:hidden;
}
.comp-box::before{
  content:'';position:absolute;top:-20px;right:-20px;width:100px;height:100px;
  border-radius:50%;background:radial-gradient(circle, rgba(0,247,82,0.15) 0%, transparent 70%);
  pointer-events:none;
}
.comp-label{font-size:9px;font-weight:700;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:.1em;margin-bottom:4px}
.comp-score{font-size:32px;font-weight:800;letter-spacing:-0.03em;color:#fff}
.comp-sub{font-size:10px;color:rgba(255,255,255,0.35);margin-top:3px;font-weight:500;line-height:1.4}

/* ── CHIPS ── */
.chips{display:flex;gap:6px;flex-wrap:wrap;margin-top:8px}
.chip{
  background:var(--slate-100);border:1px solid var(--border);
  border-radius:var(--radius);padding:5px 9px;font-size:11px;
}
.chip-label{font-size:9px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.05em}
.chip-val{font-weight:800;margin-top:1px;font-size:12px}

/* ── TABLES ── */
.table-wrap{overflow-x:auto;border-radius:var(--radius-lg);border:1px solid var(--border);box-shadow:var(--shadow-sm)}
table{width:100%;border-collapse:collapse;font-size:13px}
th{
  padding:10px 12px;text-align:left;
  font-size:9px;font-weight:700;color:var(--text3);
  text-transform:uppercase;letter-spacing:.09em;
  border-bottom:1px solid var(--border);white-space:nowrap;
  background:var(--slate-50);
}
td{padding:11px 12px;border-bottom:1px solid var(--border);color:var(--slate-600);vertical-align:middle}
tr:last-child td{border-bottom:none}
tbody tr:hover td{background:var(--slate-50);color:var(--slate-800)}
.empty-row td{text-align:center;color:var(--text3);padding:40px;font-size:12px;font-weight:600}

/* ── BADGES ── */
.badge{
  display:inline-flex;align-items:center;justify-content:center;
  padding:3px 8px;border-radius:4px;font-size:11px;font-weight:700;
  letter-spacing:0.03em;
}
.badge-A{background:rgba(0,167,76,0.12);color:var(--core-green);border:1px solid rgba(0,167,76,0.2)}
.badge-B{background:var(--blue-dim);color:var(--impact-blue);border:1px solid rgba(0,184,215,0.2)}
.badge-C{background:var(--amber-dim);color:#A96900;border:1px solid rgba(255,184,77,0.2)}
.badge-D{background:var(--red-dim);color:var(--coral);border:1px solid rgba(255,107,107,0.2)}
.team-pill{
  display:inline-block;padding:2px 8px;border-radius:4px;
  font-size:11px;font-weight:600;
  background:var(--slate-100);color:var(--slate-600);
  border:1px solid var(--border);
}
.avatar{
  width:30px;height:30px;border-radius:6px;
  background:linear-gradient(135deg,var(--mid-green),var(--mid-teal));
  display:flex;align-items:center;justify-content:center;
  font-size:11px;font-weight:800;color:#fff;
  flex-shrink:0;letter-spacing:0.02em;
}
.name-cell{display:flex;align-items:center;gap:10px}
.score-bar{height:3px;background:var(--slate-200);border-radius:2px;overflow:hidden;margin-top:4px;width:60px}
.score-fill{height:3px;border-radius:2px;transition:width .4s}
.trend{font-size:11px;font-weight:700}
.trend.up{color:var(--mid-green)}.trend.down{color:var(--coral)}.trend.flat{color:var(--text3)}

/* ── FILTER TABS ── */
.filter-tabs{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px}
.filter-tab{
  padding:5px 13px;border-radius:20px;font-size:12px;font-weight:600;
  cursor:pointer;border:1px solid var(--border2);color:var(--text2);
  background:var(--white);transition:all .15s;
}
.filter-tab:hover{color:var(--slate-700);border-color:var(--slate-400)}
.filter-tab.active{
  background:var(--accent-dim);
  border-color:var(--accent-border);
  color:var(--core-green);
}

/* ── ANALYTICS ── */
.analytics-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px}
.chart-card{
  background:var(--white);border:1px solid var(--border);
  border-radius:var(--radius-lg);padding:20px 22px;
  box-shadow:var(--shadow-sm);
}
.chart-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--slate-500);margin-bottom:14px}
.bdr-row{display:grid;grid-template-columns:160px 1fr;gap:8px;align-items:center;margin-bottom:8px}
.bar-track{background:var(--slate-100);border-radius:3px;height:6px;overflow:hidden;flex:1}
.bar-fill{height:6px;border-radius:3px;transition:width .4s}
.heatmap-row{display:flex;align-items:center;gap:5px;margin-bottom:3px}
.heatmap-cells{display:flex;gap:3px;flex:1}
.heatmap-cell{flex:1;min-width:28px;height:22px;border-radius:3px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;cursor:default}
.heatmap-cell:hover{filter:brightness(0.95)}
.setup-item{
  display:flex;align-items:center;justify-content:space-between;
  padding:9px 0;border-bottom:1px solid var(--border);
  font-size:13px;color:var(--slate-600);font-weight:500;
}
.setup-item:last-child{border-bottom:none}
.score-msg{font-size:12px;font-weight:600;padding:8px 0;min-height:28px}

/* ── PAGE HEADER ACCENT ── */
.page-header-accent{
  display:flex;align-items:center;gap:10px;
}
.page-header-flow{
  display:flex;flex-direction:column;gap:2px;padding:5px 0;
}
.phf-bar{height:3px;border-radius:2px;background:linear-gradient(90deg,var(--mid-green),var(--mid-teal))}
.phf-bar:nth-child(1){width:28px}
.phf-bar:nth-child(2){width:18px}
.phf-bar:nth-child(3){width:22px}
</style>
</head>
<body>

<!-- CONFIG SCREEN -->
<div id="config-screen" style="display:none;position:fixed;inset:0;background:var(--slate-50);z-index:1000;align-items:center;justify-content:center;flex-direction:column;">
  <div style="background:var(--white);border:1px solid var(--border);border-radius:16px;padding:40px 44px;width:100%;max-width:480px;box-shadow:var(--shadow-lg);">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:28px;">
      <div class="logo-icon" style="width:40px;height:40px;border-radius:9px;">
        <div class="logo-bar"></div><div class="logo-bar"></div><div class="logo-bar"></div>
      </div>
      <div>
        <div style="font-size:18px;font-weight:800;color:var(--slate-800);letter-spacing:-0.02em">Enable BDR Scorecard</div>
        <div style="font-size:12px;color:var(--slate-400);font-weight:500;margin-top:2px">Connect your Supabase database</div>
      </div>
    </div>
    <div class="fgroup">
      <label>Supabase Project URL</label>
      <input id="cfg-url" placeholder="https://xxxxxxxxxxxx.supabase.co" style="font-family:monospace;font-size:12px;">
    </div>
    <div class="fgroup">
      <label>Supabase Anon Key</label>
      <input id="cfg-key" placeholder="eyJhbGci..." style="font-family:monospace;font-size:12px;">
    </div>
    <div id="config-error" style="color:#CF3F44;font-size:12px;font-weight:600;min-height:20px;margin-bottom:12px;"></div>
    <button id="cfg-connect-btn" class="btn btn-primary" style="width:100%;padding:12px;" onclick="connectSupabase()">Connect to Supabase</button>
    <div style="margin-top:20px;padding-top:20px;border-top:1px solid var(--border);">
      <div style="font-size:11px;font-weight:700;color:var(--slate-500);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px;">First time? Run this SQL in Supabase → SQL Editor</div>
      <pre id="sql-block" style="background:var(--slate-800);color:#00F752;font-size:10px;padding:14px;border-radius:8px;overflow-x:auto;line-height:1.6;cursor:pointer;" title="Click to copy" onclick="copySql()">create table teams (name text primary key);
create table bdrs (id text primary key, name text not null, team text references teams(name));
create table scores (
  id text primary key,
  bdr_id text references bdrs(id),
  month text not null,
  skill_cats jsonb, skill_avg5 numeric, skill_pct int,
  eff_cats jsonb, eff_avg5 numeric, eff_pct int,
  composite int,
  unique(bdr_id, month)
);
alter table teams enable row level security;
alter table bdrs enable row level security;
alter table scores enable row level security;
create policy "public read" on teams for select using (true);
create policy "public write" on teams for all using (true);
create policy "public read" on bdrs for select using (true);
create policy "public write" on bdrs for all using (true);
create policy "public read" on scores for select using (true);
create policy "public write" on scores for all using (true);</pre>
      <div id="sql-copied" style="font-size:11px;color:var(--mid-green);font-weight:600;min-height:16px;margin-top:6px;"></div>
    </div>
  </div>
</div>

<!-- LOADING OVERLAY -->
<div id="loading-overlay" style="display:none;position:fixed;inset:0;background:rgba(248,250,251,0.85);z-index:999;align-items:center;justify-content:center;flex-direction:column;gap:12px;">
  <div style="width:36px;height:36px;border:3px solid var(--slate-200);border-top-color:var(--mid-green);border-radius:50%;animation:spin .7s linear infinite;"></div>
  <div style="font-size:13px;font-weight:600;color:var(--slate-500)">Loading data…</div>
</div>
<style>@keyframes spin{to{transform:rotate(360deg)}}</style>

<!-- APP -->
<div id="app-screen" style="display:none;height:100vh;width:100%;">
