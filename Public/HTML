function updateEffScore(catId, metricId){
  const cat=EFF_CATS.find(c=>c.id===catId);
  const m=cat.metrics.find(x=>x.id===metricId);
  const el=document.getElementById(`effval-${metricId}`);
  const scoreEl=document.getElementById(`effscore-${metricId}`);
  if(!el||!scoreEl)return;
  const raw=el.value.trim();
  if(raw===''||isNaN(+raw)){scoreEl.textContent='—';scoreEl.style.color='#555860';}
  else{
    const s=m.score(+raw);
    scoreEl.textContent=s;
    scoreEl.style.color=s>=4?'#c8f060':s===3?'#4d9fff':s===2?'#f0a840':'#f05060';
  }
  // update category avg badge
  const catScores=cat.metrics.map(mx=>{
    const e=document.getElementById(`effval-${mx.id}`);
    const v=e&&e.value.trim()!==''&&!isNaN(+e.value)?+e.value:null;
    return v!==null?mx.score(v):null;
  }).filter(x=>x!==null);
  const avgEl=document.getElementById(`effcat-avg-${catId}`);
  if(avgEl)avgEl.textContent=catScores.length?`avg ${(catScores.reduce((a,b)=>a+b,0)/catScores.length).toFixed(1)}★`:'avg —★';
  updateComposite();
}

function getEffScores(){
  // returns {catId: {metrics:[{id,label,rawVal,score}], avg}, ...}
  const result={};
  EFF_CATS.forEach(cat=>{
    const mets=cat.metrics.map(m=>{
      const el=document.getElementById(`effval-${m.id}`);
      const raw=el&&el.value.trim()!==''&&!isNaN(+el.value)?+el.value:null;
      const s=raw!==null?m.score(raw):null;
      return{id:m.id,label:m.label,unit:m.unit,rawVal:raw,score:s};
    });
    const scored=mets.filter(x=>x.score!==null);
    result[cat.id]={id:cat.id,name:cat.name,metrics:mets,avg:scored.length?+(scored.reduce((a,b)=>a+b.score,0)/scored.length).toFixed(2):null};
  });
  return result;
}

async function saveScore(){
  const bdrId=document.getElementById('s-bdr').value;
  const month=document.getElementById('s-month').value;
  if(!bdrId||!month){msg('Please select a BDR and month.','#CF3F44');return}
  const skillCats=CATS.map(cat=>({
    id:cat.id,name:cat.name,
    metrics:cat.metrics.map((name,i)=>({name,score:starVals[`${cat.id}-${i}`]||0})),
    avg:+catAvg(cat.id).toFixed(2)
  }));
  const skillAvg5=+(CATS.reduce((a,cat)=>a+catAvg(cat.id),0)/CATS.length).toFixed(2);
  const skillPct=Math.round(starPct(skillAvg5));
  const effData=getEffScores();
  const catAvgs=Object.values(effData).map(c=>c.avg).filter(x=>x!==null);
  const effAvg5=catAvgs.length?+(catAvgs.reduce((a,b)=>a+b,0)/catAvgs.length).toFixed(2):null;
  const effPct=effAvg5!==null?Math.round(starPct(effAvg5)):null;
  const composite=effPct!==null?Math.round((skillPct+effPct)/2):skillPct;
  const entry={id:'s'+Date.now(),bdrId,month,skillCats,skillAvg5,skillPct,effCats:effData,effAvg5,effPct,composite};
  msg('Saving…','#95A5AC');
  try {
    await dbSaveScore(entry);
    const idx=state.scores.findIndex(s=>s.bdrId===bdrId&&s.month===month);
    if(idx>=0)state.scores[idx]=entry;else state.scores.push(entry);
    renderTopMetrics();
    msg(`Saved — ${composite}/100  (${grade(composite)})`,'#00A74C');
  } catch(e) { msg('Error saving: '+e.message,'#CF3F44'); }
}

