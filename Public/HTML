      <td><div class="name-cell"><div class="avatar">${ini(r.b.name)}</div>
        <div><div style="font-weight:600;font-size:13px">${r.b.name}</div>
          <div class="score-bar"><div class="score-fill" style="width:${r.sc.composite}%;background:${gc}"></div></div>
