  container.querySelectorAll('.star').forEach((el,i)=>{
    el.querySelector('polygon').setAttribute('fill',(i+1)<=hover?cat.color:'#E4E9EC');
  });
  const sv=document.getElementById(`sv-${catId}-${idx}`);
  if(sv)sv.textContent=hover||saved||0;
}

function setStar(catId,idx,val){
  starVals[`${catId}-${idx}`]=val;
  renderStars(catId,idx,val,val);
  updateComposite();
}

function catAvg(catId){
  const cat=CATS.find(c=>c.id===catId);
  const vals=cat.metrics.map((_,i)=>starVals[`${catId}-${i}`]||0);
  return vals.reduce((a,b)=>a+b,0)/vals.length;
}

function updateComposite(){
  CATS.forEach(cat=>{
    const avg=catAvg(cat.id);
    const el=document.getElementById(`cavg-${cat.id}`);
    if(el)el.textContent=avg.toFixed(1)+'★';
  });
  const skillAvg5=CATS.reduce((a,cat)=>a+catAvg(cat.id),0)/CATS.length;
  const skillPct=Math.round(starPct(skillAvg5));
  // efficiency: avg of all category avgs (each cat avg is 1-5, convert to 0-100)
  const effData=getEffScores();
  const catAvgs=Object.values(effData).map(c=>c.avg).filter(x=>x!==null);
  const effAvg5=catAvgs.length?catAvgs.reduce((a,b)=>a+b,0)/catAvgs.length:null;
  const effPct=effAvg5!==null?Math.round(starPct(effAvg5)):null;
  const comp=effPct!==null?Math.round((skillPct+effPct)/2):skillPct;
  const g=grade(comp);const gc=gradeColor(g);
  document.getElementById('comp-score').textContent=comp;
  document.getElementById('comp-score').style.color=gc;
  document.getElementById('comp-grade').textContent=g;
  document.getElementById('comp-grade').style.color=gc;
  document.getElementById('comp-sub').textContent=`Skill ${skillAvg5.toFixed(2)}★ → ${skillPct}% · Efficiency ${effAvg5!==null?effAvg5.toFixed(2)+'★ → '+effPct+'%':'not entered'}`;
  document.getElementById('cat-chips').innerHTML=CATS.map(cat=>`
    <div class="chip">
      <div class="chip-label">${cat.name.split(' ')[0].slice(0,8)}</div>
      <div class="chip-val" style="color:${cat.color}">${catAvg(cat.id).toFixed(1)}★</div>
    </div>`).join('');
}

