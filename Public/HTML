      if(avg===null)return`<div class="heatmap-cell" style="background:#F1F4F6;color:#CED7DC;min-width:28px" title="${m}: no data">—</div>`;
      const pct=avg/5;
      const r=parseInt(cat.color.slice(1,3),16),g2=parseInt(cat.color.slice(3,5),16),bl=parseInt(cat.color.slice(5,7),16);
      const a=(0.12+pct*0.6).toFixed(2);
      const txtColor=pct>0.5?cat.color:cat.color;
      return`<div class="heatmap-cell" style="background:rgba(${r},${g2},${bl},${a});color:${cat.color};min-width:28px;font-weight:700" title="${b.name} — ${m}: ${avg}★">${avg}</div>`;
    }).join('');
    return`<div class="heatmap-row">
      <div style="display:flex;align-items:center;gap:5px;width:110px;flex-shrink:0">
        <div class="avatar" style="width:20px;height:20px;font-size:9px">${ini(b.name)}</div>
        <span style="font-size:11px;color:#64757E;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${b.name.split(' ')[0]}</span>
      </div>
      <div class="heatmap-cells">${cells}</div></div>`;
  }).join('');
  hEl.innerHTML=html;
}

// ── HISTORY ──────────────────────────────────────────────────────────────────
function renderHistory(){
  const bdrF=document.getElementById('h-bdr').value;
  const teamF=document.getElementById('h-team').value;
  const monthF=document.getElementById('h-month').value;
  const bdrSel=document.getElementById('h-bdr');const bc=bdrSel.value;
  bdrSel.innerHTML='<option value="">All BDRs</option>'+state.bdrs.map(b=>`<option value="${b.id}">${b.name}</option>`).join('');
  if(bc)bdrSel.value=bc;
  const teamSel=document.getElementById('h-team');const tc=teamSel.value;
  teamSel.innerHTML='<option value="">All teams</option>'+state.teams.map(t=>`<option value="${t}">${t}</option>`).join('');
  if(tc)teamSel.value=tc;
  let sc=[...state.scores].sort((a,b)=>b.month.localeCompare(a.month));
  if(bdrF)sc=sc.filter(s=>s.bdrId===bdrF);
  if(teamF){const ids=state.bdrs.filter(b=>b.team===teamF).map(b=>b.id);sc=sc.filter(s=>ids.includes(s.bdrId))}
  if(monthF)sc=sc.filter(s=>s.month===monthF);
  const tbody=document.getElementById('hist-body');
  if(!sc.length){tbody.innerHTML=`<tr class="empty-row"><td colspan="12">No scores match filters</td></tr>`;return}
  tbody.innerHTML=sc.map(s=>{
    const b=state.bdrs.find(x=>x.id===s.bdrId);if(!b)return'';
    const g=grade(s.composite),gc=gradeColor(g);
    const gc2=id=>(s.skillCats||[]).find(c=>c.id===id)?.avg??'—';
    return`<tr>
      <td style="font-weight:600;font-size:11px;color:#95A5AC">${mLabel(s.month)}</td>
      <td><div class="name-cell"><div class="avatar" style="width:26px;height:26px;font-size:10px">${ini(b.name)}</div>
        <span style="font-weight:600">${b.name}</span></div></td>
      <td><span class="team-pill">${b.team}</span></td>
      <td style="font-weight:600;font-size:12px">${gc2('prospecting')}★</td>
      <td style="font-weight:600;font-size:12px">${gc2('discovery')}★</td>
      <td style="font-weight:600;font-size:12px">${gc2('tools')}★</td>
      <td style="font-weight:600;font-size:12px">${gc2('professionalism')}★</td>
      <td style="font-weight:600">${s.skillAvg5}★</td>
      <td style="font-weight:600;font-size:12px">${s.effCats?.activity?.avg!=null?s.effCats.activity.avg+'★':'—'}</td>
      <td style="font-weight:600;font-size:12px">${s.effCats?.conversions?.avg!=null?s.effCats.conversions.avg+'★':'—'}</td>
      <td style="font-weight:600">${s.effAvg5!=null?s.effAvg5+'★':'—'}</td>
      <td style="font-weight:600;font-weight:700;color:${gc}">${s.composite}</td>
      <td><span class="badge badge-${g}">${g}</span></td>
      <td><button class="btn btn-danger btn-sm" onclick="delScore('${s.id}')">×</button></td></tr>`;
  }).join('');
}

async function delScore(id){
  if(!confirm('Delete this score?'))return;
  try {
    await dbDeleteScore(id);
    state.scores=state.scores.filter(s=>s.id!==id);
    renderHistory();renderTopMetrics();
  } catch(e) { alert('Error deleting: '+e.message); }
}

// ── SETUP ────────────────────────────────────────────────────────────────────
function renderSetup(){
  document.getElementById('teams-list').innerHTML=state.teams.map((t,i)=>
    `<div class="setup-item">${t}<button class="btn btn-danger btn-sm" onclick="rmTeam(${i})">×</button></div>`
  ).join('')||`<div style="color:#95A5AC;font-size:12px;font-weight:600">No teams</div>`;
  document.getElementById('bdrs-list').innerHTML=state.bdrs.map((b,i)=>
    `<div class="setup-item"><div class="name-cell">
      <div class="avatar" style="width:24px;height:24px;font-size:10px">${ini(b.name)}</div>
      <span style="font-weight:600">${b.name}</span><span class="team-pill" style="margin-left:6px">${b.team}</span>
    </div><button class="btn btn-danger btn-sm" onclick="rmBDR(${i})">×</button></div>`
  ).join('')||`<div style="color:#95A5AC;font-size:12px;font-weight:600">No BDRs</div>`;
  document.getElementById('new-bdr-team').innerHTML='<option value="">Select team...</option>'+state.teams.map(t=>`<option value="${t}">${t}</option>`).join('');
  document.getElementById('eff-cat-preview').innerHTML=EFF_CATS.map(cat=>`
    <div style="margin-bottom:10px;padding:12px 14px;background:var(--bg3);border-radius:var(--radius);border:1px solid var(--border)">
      <div style="font-size:12px;font-weight:700;color:${cat.color};margin-bottom:8px">${cat.icon} ${cat.name}</div>
      ${cat.metrics.map(m=>`
        <div style="margin-bottom:6px;padding:6px 8px;background:var(--bg4);border-radius:5px">
          <div style="font-size:12px;color:var(--text2);margin-bottom:3px">${m.label} <span style="color:var(--text3);font-size:10px;font-weight:600">(${m.unit})</span></div>
          <div style="font-size:10px;color:var(--text3);font-weight:600">${m.hint}</div>
        </div>`).join('')}
    </div>`).join('');
  document.getElementById('cat-preview').innerHTML=CATS.map(cat=>`
    <div style="margin-bottom:10px;padding:12px 14px;background:var(--bg3);border-radius:var(--radius);border:1px solid var(--border)">
      <div style="font-size:12px;font-weight:700;color:${cat.color};margin-bottom:6px">${cat.icon} ${cat.name}</div>
      <div style="display:flex;flex-wrap:wrap;gap:5px">
        ${cat.metrics.map(m=>`<span style="font-size:11px;font-weight:600;background:var(--bg4);padding:3px 8px;border-radius:4px;color:#64757E">${m}</span>`).join('')}
      </div></div>`).join('');
}

async function addTeam(){
  const v=document.getElementById('new-team').value.trim();
  if(!v||state.teams.includes(v))return;
  try { await dbSaveTeam(v); state.teams.push(v); document.getElementById('new-team').value=''; renderSetup();initScore(); }
  catch(e){alert('Error: '+e.message);}
}
async function rmTeam(i){
  const name=state.teams[i];
  if(!confirm(`Remove team "${name}"?`))return;
  try { await dbDeleteTeam(name); state.teams.splice(i,1); renderSetup(); }
  catch(e){alert('Error: '+e.message);}
}
async function addBDR(){
  const name=document.getElementById('new-bdr-name').value.trim();
  const team=document.getElementById('new-bdr-team').value;
  if(!name||!team)return;
  const bdr={id:'b'+Date.now(),name,team};
  try { await dbSaveBDR(bdr); state.bdrs.push(bdr); document.getElementById('new-bdr-name').value=''; renderSetup();initScore(); }
  catch(e){alert('Error: '+e.message);}
}
async function rmBDR(i){
  const bdr=state.bdrs[i];
  if(!confirm(`Remove ${bdr.name}?`))return;
  try { await dbDeleteBDR(bdr.id); state.bdrs.splice(i,1); renderSetup();initScore(); }
  catch(e){alert('Error: '+e.message);}
}

function exportData(){
  const blob=new Blob([JSON.stringify(state,null,2)],{type:'application/json'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='bdr-scorecard.json';a.click();
}

async function confirmReset(){
  if(!confirm('Reset ALL data? This will delete everything from the database.'))return;
  try {
    await sb.from('scores').delete().neq('id','__none__');
    await sb.from('bdrs').delete().neq('id','__none__');
    await sb.from('teams').delete().neq('name','__none__');
    state={teams:[],bdrs:[],scores:[]};
    init();renderSetup();
  } catch(e){alert('Error: '+e.message);}
}

async function refreshData(){
  setLoading(true);
  try { await dbLoad(); } catch(e){alert('Refresh failed: '+e.message);}
  setLoading(false);
  initScore();
  const activePage=document.querySelector('.page.active')?.id?.replace('page-','');
  if(activePage==='leaderboard')renderLeaderboard();
  else if(activePage==='analytics')renderAnalytics();
  else if(activePage==='history')renderHistory();
  else if(activePage==='setup')renderSetup();
  else renderTopMetrics();
}

init();
</script>
</body>
</html>
