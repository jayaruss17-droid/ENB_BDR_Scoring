<script>
// ── SKILL CATEGORIES (fixed structure) ──────────────────────────────────────
const CATS = [
  { id:'prospecting', name:'Prospecting Quality', icon:'🎯', color:'#00A74C',
    metrics:['Account Research','Multi-threading','Messaging & Communication','Objection Handling','Personalisation'] },
  { id:'discovery', name:'Discovery', icon:'🔍', color:'#00B8D7',
    metrics:['Ability to identify L2 pain','CoM usage & Competency','Product Knowledge'] },
  { id:'tools', name:'Tools Mastery', icon:'🛠️', color:'#8B5CF6',
    metrics:['SFDC Hygiene','Clari/Groove competency','Zoominfo competency','Salesnav competency','AI usage & competency'] },
  { id:'professionalism', name:'Professionalism & Coachability', icon:'🌟', color:'#15BB7F',
    metrics:['Receptive to feedback','Implements changes quickly','Positive mindset','Time management'] }
];

// ── EFFICIENCY CATEGORIES (fixed, value-based auto-scoring 1–5) ─────────────
const EFF_CATS = [
  {
    id:'activity', name:'Activity', icon:'📞', color:'#00B8D7',
    metrics:[
      { id:'calls_per_day', label:'Avg calls per day', unit:'calls', placeholder:'e.g. 45',
        hint:'Expectation: 50 = score 3',
        score: v => v>=70?5:v>=60?4:v>=50?3:v>=35?2:1 },
      { id:'connected_call_pct', label:'Connected call %', unit:'%', placeholder:'e.g. 5.5',
        hint:'<3%=1 · 3–4.9%=2 · 5–6.9%=3 · 7–8.9%=4 · >9%=5',
        score: v => v>=9?5:v>=7?4:v>=5?3:v>=3?2:1 },
      { id:'on_time_flow', label:'On-time flow steps', unit:'%', placeholder:'e.g. 88',
        hint:'<70%=1 · 70–79%=2 · 80–89%=3 · 90–99%=4 · 100%=5',
        score: v => v>=100?5:v>=90?4:v>=80?3:v>=70?2:1 },
      { id:'skipped_flow', label:'Skipped flow steps', unit:'%', placeholder:'e.g. 2.5',
        hint:'>5%=1 · 3–5%=2 · 2–2.9%=3 · 1.1–1.9%=4 · ≤1%=5',
        score: v => v<=1?5:v<=1.9?4:v<=2.9?3:v<=5?2:1 },
    ]
  },
  {
    id:'conversions', name:'Conversions', icon:'🎯', color:'#15BB7F',
    metrics:[
      { id:'conversation_pct', label:'Conversation %', unit:'%', placeholder:'e.g. 60',
        hint:'0–24%=1 · 25–49%=2 · 50–69%=3 · 70–84%=4 · 85–100%=5',
        score: v => v>=85?5:v>=70?4:v>=50?3:v>=25?2:1 },
      { id:'conv_to_meeting_pct', label:'Conversation to meeting %', unit:'%', placeholder:'e.g. 18',
        hint:'<10%=1 · 10–14%=2 · 15–19%=3 · 20–24%=4 · ≥25%=5',
        score: v => v>=25?5:v>=20?4:v>=15?3:v>=10?2:1 },
    ]
  }
];

// ── SUPABASE CONFIG ──────────────────────────────────────────────────────────
const CFG_KEY = 'sb_config_v1';
let SB_URL = '', SB_KEY = '';
let sb = null; // supabase client

function loadConfig(){
  try { const c=localStorage.getItem(CFG_KEY); if(c){const p=JSON.parse(c);SB_URL=p.url;SB_KEY=p.key;} } catch(e){}
}
function saveConfig(url,key){
  localStorage.setItem(CFG_KEY,JSON.stringify({url,key}));
  SB_URL=url; SB_KEY=key;
}

function initSupabase(){
  sb = window.supabase.createClient(SB_URL, SB_KEY);
}

// ── STATE ────────────────────────────────────────────────────────────────────
let state = { teams:[], bdrs:[], scores:[] };
const TEAM_COLORS = ['#00A74C','#00B8D7','#8B5CF6','#FFB84D','#FF3E9D','#15BB7F'];

// ── DB OPERATIONS ────────────────────────────────────────────────────────────
async function dbLoad(){
  const [t,b,s] = await Promise.all([
    sb.from('teams').select('*').order('name'),
    sb.from('bdrs').select('*').order('name'),
    sb.from('scores').select('*').order('month',{ascending:false})
  ]);
  state.teams = (t.data||[]).map(r=>r.name);
  state.bdrs  = (b.data||[]).map(r=>({id:r.id,name:r.name,team:r.team}));
  state.scores= (s.data||[]).map(r=>({
    id:r.id, bdrId:r.bdr_id, month:r.month,
    skillCats:r.skill_cats, skillAvg5:r.skill_avg5, skillPct:r.skill_pct,
    effCats:r.eff_cats, effAvg5:r.eff_avg5, effPct:r.eff_pct,
    composite:r.composite
  }));
}

async function dbSaveTeam(name){
  const {error}=await sb.from('teams').upsert({name},{onConflict:'name'});
  if(error)throw error;
}
async function dbDeleteTeam(name){
  const {error}=await sb.from('teams').delete().eq('name',name);
  if(error)throw error;
}
async function dbSaveBDR(bdr){
  const {error}=await sb.from('bdrs').upsert({id:bdr.id,name:bdr.name,team:bdr.team});
  if(error)throw error;
}
async function dbDeleteBDR(id){
  const {error}=await sb.from('bdrs').delete().eq('id',id);
  if(error)throw error;
}
async function dbSaveScore(entry){
  const row={
    id:entry.id, bdr_id:entry.bdrId, month:entry.month,
    skill_cats:entry.skillCats, skill_avg5:entry.skillAvg5, skill_pct:entry.skillPct,
    eff_cats:entry.effCats, eff_avg5:entry.effAvg5, eff_pct:entry.effPct,
    composite:entry.composite
  };
  const {error}=await sb.from('scores').upsert(row,{onConflict:'bdr_id,month'});
  if(error)throw error;
}
async function dbDeleteScore(id){
  const {error}=await sb.from('scores').delete().eq('id',id);
  if(error)throw error;
}

// ── UTILS ────────────────────────────────────────────────────────────────────
const ini = n => n.split(' ').map(x=>x[0]).join('').slice(0,2).toUpperCase();
const grade = s => s>=85?'A':s>=70?'B':s>=55?'C':'D';
const gradeColor = g => g==='A'?'#00A74C':g==='B'?'#00B8D7':g==='C'?'#A96900':'#CF3F44';
const scoreColor = s => gradeColor(grade(s));
const starPct = v => Math.round((v/5)*100);
function prevMonth(m){const d=new Date(m+'-01');d.setMonth(d.getMonth()-1);return d.toISOString().slice(0,7)}
function mLabel(m){const[y,mo]=m.split('-');return new Date(+y,+mo-1,1).toLocaleString('default',{month:'short',year:'2-digit'})}
function getMonths(period){
  if(period==='all')return[...new Set(state.scores.map(s=>s.month))].sort();
  const n=parseInt(period),now=new Date(),out=[];
  for(let i=n-1;i>=0;i--){const d=new Date(now.getFullYear(),now.getMonth()-i,1);out.push(d.toISOString().slice(0,7))}
  return out;
}

// ── NAV ──────────────────────────────────────────────────────────────────────
function showPage(p,el){
  document.querySelectorAll('.page').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(x=>x.classList.remove('active'));
  document.getElementById('page-'+p).classList.add('active');
  if(el)el.classList.add('active');
  if(p==='score')initScore();
  if(p==='leaderboard')renderLeaderboard();
  if(p==='analytics')renderAnalytics();
  if(p==='history')renderHistory();
  if(p==='setup')renderSetup();
}

// ── INIT ─────────────────────────────────────────────────────────────────────
async function init(){
  loadConfig();
  if(!SB_URL||!SB_KEY){ showConfigScreen(); return; }
  initSupabase();
  showAppScreen();
  setLoading(true);
  try {
    await dbLoad();
  } catch(e) {
    showConfigScreen('Could not connect — check your URL and key.');
    return;
  }
  setLoading(false);
  const m=new Date().toISOString().slice(0,7);
  document.getElementById('s-month').value=m;
  document.getElementById('lb-month').value=m;
  document.getElementById('topbar-date').textContent=new Date().toLocaleString('default',{month:'long',year:'numeric'});
  initScore();
}

function setLoading(on){
  document.getElementById('loading-overlay').style.display=on?'flex':'none';
}

function showConfigScreen(err){
  document.getElementById('config-screen').style.display='flex';
  document.getElementById('app-screen').style.display='none';
  if(err) document.getElementById('config-error').textContent=err;
  // pre-fill if saved
  if(SB_URL) document.getElementById('cfg-url').value=SB_URL;
  if(SB_KEY) document.getElementById('cfg-key').value=SB_KEY;
}

function showAppScreen(){
  document.getElementById('config-screen').style.display='none';
  document.getElementById('app-screen').style.display='flex';
}

async function connectSupabase(){
  const url=document.getElementById('cfg-url').value.trim();
  const key=document.getElementById('cfg-key').value.trim();
  if(!url||!key){ document.getElementById('config-error').textContent='Please fill in both fields.'; return; }
  document.getElementById('cfg-connect-btn').textContent='Connecting...';
  document.getElementById('cfg-connect-btn').disabled=true;
  saveConfig(url,key);
  initSupabase();
  try {
    await dbLoad();
    showAppScreen();
    setLoading(false);
    const m=new Date().toISOString().slice(0,7);
    document.getElementById('s-month').value=m;
    document.getElementById('lb-month').value=m;
    document.getElementById('topbar-date').textContent=new Date().toLocaleString('default',{month:'long',year:'numeric'});
    initScore();
  } catch(e) {
    document.getElementById('config-error').textContent='Connection failed: '+e.message;
    document.getElementById('cfg-connect-btn').textContent='Connect';
    document.getElementById('cfg-connect-btn').disabled=false;
  }
}

// ── SCORE PAGE ───────────────────────────────────────────────────────────────
// star values stored as map: "catId-idx" -> 1..5 (0 = unset)
let starVals = {};

function initScore(){
  const sel=document.getElementById('s-bdr');
  const cur=sel.value;
  sel.innerHTML='<option value="">Select BDR...</option>'+state.bdrs.map(b=>`<option value="${b.id}">${b.name} (${b.team})</option>`).join('');
  if(cur)sel.value=cur;
  renderCats();
  renderEffInputs();
  renderTopMetrics();
}

function renderCats(){
  document.getElementById('skill-cats-container').innerHTML=CATS.map(cat=>`
    <div class="skill-cat">
      <div class="skill-cat-header">
        <div class="cat-icon" style="background:${cat.color}22">${cat.icon}</div>
        <span class="cat-label" style="color:${cat.color}">${cat.name}</span>
        <span class="cat-avg-badge" id="cavg-${cat.id}">—★</span>
      </div>
      ${cat.metrics.map((m,i)=>starRowHTML(cat,i,m)).join('')}
    </div>
  `).join('');
  // restore saved values
  Object.entries(starVals).forEach(([key,val])=>{
    const[catId,idx]=key.split('-');
    renderStars(catId,+idx,val,val);
  });
  updateComposite();
}

